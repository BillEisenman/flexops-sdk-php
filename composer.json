{
  "name": "flexops/sdk",
  "description": "Official FlexOps multi-carrier shipping platform SDK",
  "type": "library",
  "license": "MIT",
  "homepage": "https://flexops.io",
  "support": {
    "issues": "https://github.com/BillEisenman/flexops-sdk-php/issues",
    "source": "https://github.com/BillEisenman/flexops-sdk-php"
  },
  "authors": [
    { "name": "FlexOps, LLC", "email": "support@flexops.io" }
  ],
  "require": {
    "php": ">=8.1",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5 || ^11.0"
  },
  "autoload": {
    "psr-4": {
      "FlexOps\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "FlexOps\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}
